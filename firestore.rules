rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User profiles: Only the user can read/write their own profile
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Clinical Records (Diagnoses): Only the user can read/write their own records
    match /diagnoses/{recordId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Chat History: Only the user can read/write their own chat logs
    match /chat_history/{chatId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Appointments: Users can read/write their own, doctors can read their assigned ones
    match /appointments/{appointmentId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        resource.data.doctorId == request.auth.uid
      );
    }

    // Doctor profiles: Publicly readable for authenticated users, but no one can write (admin only in real prod)
    match /doctors/{doctorId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only allow through console or admin SDK
    }
  }
}
